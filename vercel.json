{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/p/:slug", "destination": "/public/viewer.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
