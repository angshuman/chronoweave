# ChronoWeave — set ONE of these API keys and start the server.
# The server auto-detects the provider based on which key is set.
# Priority: ANTHROPIC_API_KEY > OPENAI_API_KEY > XAI_API_KEY

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o)
# OPENAI_API_KEY=sk-...

# xAI (Grok)
# XAI_API_KEY=xai-...

# Server port (default: 8000)
# PORT=8000
